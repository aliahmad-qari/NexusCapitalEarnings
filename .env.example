VITE_API_URL=https://nexuscapitalearnings.onrender.com
VITE_GEMINI_API_KEY=your_key_here

# Backend Environment Variables (for Render)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/nexuscapital
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
PORT=3000
NODE_ENV=production

# Primary production frontend URL (always allowed)
FRONTEND_URL=https://roiwealth.vercel.app

# Optional: comma-separated list of additional allowed origins
# Use this for staging URLs or custom domains
# ADDITIONAL_ORIGINS=https://staging.example.com,https://custom-domain.com

# Note: ALL *.vercel.app subdomains are automatically allowed (handles preview deploys)

# Business Rules (configurable without code changes)
REFERRAL_REWARD_PKR=85
